# `serve` configuration. All `*_MS` values and the pool size must be non-zero.
#
# Local development database (compose.yaml).
DATABASE_URL=postgres://koine:koine@localhost:5432/koine

# Required bearer token for every worker. Replace before running `serve`.
KOINE_WORKER_TOKEN=change-me

# gRPC bind address (default: 0.0.0.0:7419).
KOINE_GRPC_ADDR=0.0.0.0:7419

# Maximum worker lease TTL in milliseconds (default: 300000; must be non-zero).
KOINE_MAX_LEASE_TTL_MS=300000

# Correctness fallback for a drained Fetch stream in milliseconds
# (default: 1000; must be non-zero).
KOINE_IDLE_POLL_MS=1000

# Maximum operational Postgres connections (default: 16; must be non-zero).
# `serve` also holds one separate listener connection, so budget N + 1 total
# client connections for this process.
# Presence skips its update if this pool is saturated and bounds an acquired
# write to 100 ms. Review N before phase 3 adds relay/sink concurrency.
KOINE_DB_MAX_CONNECTIONS=16

# Maximum operational-pool acquisition wait in milliseconds
# (default: 5000; must be non-zero).
KOINE_DB_ACQUIRE_TIMEOUT_MS=5000
